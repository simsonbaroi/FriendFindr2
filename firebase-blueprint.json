{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string" },
        "searchVisible": { "type": "boolean" },
        "allowRequests": { "type": "boolean" },
        "photoURL": { "type": "string" },
        "profession": { "type": "string" },
        "bio": { "type": "string" },
        "country": { "type": "string" },
        "tags": { "type": "array" },
        "blockedUsers": { "type": "array" }
      },
      "required": ["uid", "displayName", "username", "email", "searchVisible", "allowRequests"]
    },
    "Request": {
      "title": "Friend Request",
      "description": "Friend request between two users",
      "type": "object",
      "properties": {
        "fromUid": { "type": "string" },
        "toUid": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fromUid", "toUid", "status"]
    },
    "Chat": {
      "title": "Chat Session",
      "description": "A chat session between two users",
      "type": "object",
      "properties": {
        "participants": { "type": "array" },
        "lastMessage": { "type": "string" },
        "lastMessageTime": { "type": "string", "format": "date-time" }
      },
      "required": ["participants"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "An individual message in a chat",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/requests/{requestId}": {
      "schema": "Request",
      "description": "Friend requests"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat metadata"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat messages"
    }
  }
}
